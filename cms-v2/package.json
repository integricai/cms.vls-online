{
  "name": "cms-v2",
  "version": "1.0.0",
  "description": "CMS v2 — Node.js + TypeScript + Express",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/db/migrate.ts",
    "import-blob": "ts-node src/db/import-blob.ts",
    "seed-user": "ts-node src/db/seed-user.ts"
  },
  "dependencies": {
    "@sparticuz/chromium": "^123.0.1",
    "@neondatabase/serverless": "^0.9.5",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "puppeteer-core": "^22.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
