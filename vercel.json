{
  "version": 2,
  "builds": [
    {
      "src": "cms-v2/src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "cms-v2/client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "cms-v2/src/server.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}